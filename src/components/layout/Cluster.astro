---
interface Props {
  gap?: "xs" | "sm" | "md" | "lg";
  justify?: "start" | "center" | "between";
  class?: string;
}

const {
  gap = "md",
  justify = "start",
  class: className = "",
} = Astro.props;
---

<div class:list={[
  "l-cluster",
  `l-cluster--${gap}`,
  `l-cluster--${justify}`,
  className,
]}>
  <slot />
</div>