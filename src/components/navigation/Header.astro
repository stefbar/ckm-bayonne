---
import Container from "../layout/Container.astro"
import Button from "../ui/Button.astro"
import { Image } from "astro:assets"
import headerLogo from "../../assets/images/ckm-logo-442x437.png"

const nav = [
    { label: "Le club", href: "/club" },
    { label: "La méthode", href: "/methode" },
    { label: "Les cours", href: "/cours" },
    { label: "Témoignages", href: "/temoignages" },
    { label: "FAQ", href: "/faq" },
]
---

<header class="site-header">

    <Container>
      
        <div class="site-header__inner">

            <!-- Logo -->
            <a href="/" class="site-header__brand">
                <Image src={headerLogo} alt="CKM Bayonne" width={40} height={40} />
                CKM Bayonne
            </a>

            <!-- Nav -->
            <nav class="site-nav">
                {nav.map((item) => (
                    <a
                        href={item.href}
                        class="text-sm text-gray-700 hover:text-black transition"
                    >
                        {item.label}
                    </a>
                ))}
            </nav>

            <!-- CTA -->
            <Button href="/contact" size="sm">
                1er cours offert
            </Button>

            <!-- Mobile placeholder -->
            <button class="md:hidden text-sm">
                Menu
            </button>

        </div>

    </Container>

</header>