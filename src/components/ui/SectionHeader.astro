---
import Eyebrow from "../typography/Eyebrow.astro";
import Heading from "../typography/Heading.astro";
import Text from "../typography/Text.astro";
import Stack from "../layout/Stack.astro";

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const {
  eyebrow,
  title,
  description,
} = Astro.props;
---

<Stack gap="sm">

  {eyebrow && <Eyebrow>{eyebrow}</Eyebrow>}

  <Heading level={2}>
    {title}
  </Heading>

  {description && (
    <Text muted>
      {description}
    </Text>
  )}

</Stack>