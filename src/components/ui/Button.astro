---
interface Props {
  href?: string
  variant?: "primary" | "secondary" | "ghost"
  size?: "sm" | "md" | "lg"
  class?: string
}

const {
  href,
  variant = "primary",
  class: className = "",
} = Astro.props

const Tag = href ? "a" : "button"
---

<Tag
  href={href}
  class={
    `btn btn--${variant} ${className}`
  }
>
  <slot />
</Tag>