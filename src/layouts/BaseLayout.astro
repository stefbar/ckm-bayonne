---
import Header from "../components/navigation/Header.astro"
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;

---

<!doctype html>
<html lang="fr">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{title}</title>
    </head>

    <body>
        <Header />
        <slot />
    </body>
</html>